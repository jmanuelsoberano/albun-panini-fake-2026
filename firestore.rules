rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function safeProfileCreate() {
      return request.resource.data.keys().hasOnly([
          'nickname',
          'avatarId',
          'coins',
          'packsAvailable',
          'packsOpened',
          'starterPackClaimed',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.nickname is string
        && request.resource.data.avatarId is string
        && request.resource.data.coins == 0
        && request.resource.data.packsAvailable == 0
        && request.resource.data.packsOpened == 0
        && request.resource.data.starterPackClaimed == false;
    }

    function safeProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'nickname',
        'avatarId',
        'updatedAt'
      ]);
    }

    function safeRoomCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'code',
          'name',
          'ownerId',
          'memberIds',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'code',
          'name',
          'ownerId',
          'memberIds',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.code is string
        && request.resource.data.name is string
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() <= 12;
    }

    function safeRoomUpdate() {
      return signedIn()
        && request.auth.uid in resource.data.memberIds
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberIds',
          'updatedAt'
        ])
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.code == resource.data.code
        && request.resource.data.name == resource.data.name
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() <= 12;
    }

    function safeTradeCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'fromUserId',
          'toUserId',
          'roomId',
          'offered',
          'requested',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'fromUserId',
          'toUserId',
          'roomId',
          'offered',
          'requested',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && (request.resource.data.roomId == null || request.resource.data.roomId is string)
        && request.resource.data.offered is list
        && request.resource.data.requested is list
        && request.resource.data.offered.size() > 0
        && request.resource.data.requested.size() > 0
        && request.resource.data.offered.size() <= 8
        && request.resource.data.requested.size() <= 8
        && request.resource.data.status == 'pending';
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && safeProfileCreate();
      allow update: if isOwner(userId) && safeProfileUpdate();
      allow delete: if false;
    }

    match /users/{userId}/inventory/{stickerId} {
      allow read: if isOwner(userId);
      allow write: if false; // Solo Cloud Functions debe modificar inventario.
    }

    match /users/{userId}/missions/{missionId} {
      allow read: if isOwner(userId);
      allow write: if false; // Solo Cloud Functions debe otorgar recompensas.
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create, update: if false; // Solo Cloud Functions debe crear o actualizar salas.
      allow delete: if false;

      match /members/{userId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
        allow create, update: if false; // Solo Cloud Functions debe administrar miembros.
        allow delete: if false;
      }
    }

    match /trades/{tradeId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      allow create, update, delete: if false; // Crear/aceptar/cancelar debe pasar por Cloud Functions.
    }

    match /packOpenings/{openingId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false; // Solo Cloud Functions debe registrar aperturas.
    }

    match /catalog/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
