rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function safeProfileCreate() {
      return request.resource.data.keys().hasOnly([
          'nickname',
          'avatarId',
          'coins',
          'packsAvailable',
          'packsOpened',
          'starterPackClaimed',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.nickname is string
        && request.resource.data.avatarId is string
        && request.resource.data.coins == 0
        && request.resource.data.packsAvailable == 0
        && request.resource.data.packsOpened == 0
        && request.resource.data.starterPackClaimed == false;
    }

    function safeProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'nickname',
        'avatarId',
        'updatedAt'
      ]);
    }

    function validMissionId(missionId) {
      return missionId in ['firstPack', 'tenPercent', 'holoHunter', 'fullTeam'];
    }

    function safeMissionClaim(userId, missionId) {
      return isOwner(userId)
        && validMissionId(missionId)
        && request.resource.data.keys().hasOnly([
          'claimed',
          'claimedAt',
          'reward'
        ])
        && request.resource.data.claimed == true
        && request.resource.data.reward.coins == 25
        && request.resource.data.reward.packsAvailable == 1;
    }

    function safeMissionRewardProfile(userId) {
      let missionId = request.resource.data.lastMissionRewardId;
      let missionPath = /databases/$(database)/documents/users/$(userId)/missions/$(missionId);
      return isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'coins',
          'packsAvailable',
          'lastMissionRewardId',
          'updatedAt'
        ])
        && missionId is string
        && validMissionId(missionId)
        && !exists(missionPath)
        && getAfter(missionPath).data.claimed == true
        && getAfter(missionPath).data.reward.coins == 25
        && getAfter(missionPath).data.reward.packsAvailable == 1
        && request.resource.data.coins == resource.data.coins + 25
        && request.resource.data.packsAvailable == resource.data.packsAvailable + 1;
    }

    function safeStarterClaim() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'starterPackClaimed',
          'packsAvailable',
          'updatedAt'
        ])
        && resource.data.starterPackClaimed == false
        && request.resource.data.starterPackClaimed == true
        && request.resource.data.packsAvailable == resource.data.packsAvailable + 1;
    }

    function safeClientPackOpenProfile() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'packsAvailable',
          'packsOpened',
          'updatedAt'
        ])
        && resource.data.packsAvailable > 0
        && request.resource.data.packsAvailable == resource.data.packsAvailable - 1
        && request.resource.data.packsOpened == resource.data.packsOpened + 1;
    }

    function clientPackOpenAfter(userId) {
      let before = get(/databases/$(database)/documents/users/$(userId)).data;
      let after = getAfter(/databases/$(database)/documents/users/$(userId)).data;
      return after.packsAvailable == before.packsAvailable - 1
        && after.packsOpened == before.packsOpened + 1;
    }

    function validClientOpening(userId, openingId, stickerId) {
      let opening = getAfter(/databases/$(database)/documents/packOpenings/$(openingId)).data;
      return opening.userId == userId
        && opening.source == 'firestore-client'
        && opening.stickerIds is list
        && opening.stickerIds.size() == 5
        && stickerId in opening.stickerIds;
    }

    function safeInventoryCreate(userId, stickerId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'stickerId',
          'copies',
          'lastOpeningId',
          'updatedAt'
        ])
        && request.resource.data.stickerId == stickerId
        && request.resource.data.copies == 1
        && request.resource.data.lastOpeningId is string
        && clientPackOpenAfter(userId)
        && validClientOpening(userId, request.resource.data.lastOpeningId, stickerId);
    }

    function safeInventoryUpdate(userId, stickerId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'stickerId',
          'copies',
          'lastOpeningId',
          'updatedAt'
        ])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'copies',
          'lastOpeningId',
          'updatedAt'
        ])
        && request.resource.data.stickerId == resource.data.stickerId
        && request.resource.data.stickerId == stickerId
        && request.resource.data.copies == resource.data.copies + 1
        && request.resource.data.lastOpeningId is string
        && clientPackOpenAfter(userId)
        && validClientOpening(userId, request.resource.data.lastOpeningId, stickerId);
    }

    function safeRoomCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'code',
          'name',
          'ownerId',
          'memberIds',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'code',
          'name',
          'ownerId',
          'memberIds',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.code is string
        && request.resource.data.name is string
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberIds is list
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.memberIds.size() <= 12;
    }

    function safeRoomUpdate() {
      return signedIn()
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberIds',
          'updatedAt'
        ])
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.code == resource.data.code
        && request.resource.data.name == resource.data.name
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.size() >= resource.data.memberIds.size()
        && request.resource.data.memberIds.size() <= 12;
    }

    function safeTradeCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'fromUserId',
          'toUserId',
          'roomId',
          'offered',
          'requested',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.keys().hasAll([
          'fromUserId',
          'toUserId',
          'roomId',
          'offered',
          'requested',
          'status',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && (request.resource.data.roomId == null || request.resource.data.roomId is string)
        && request.resource.data.offered is list
        && request.resource.data.requested is list
        && request.resource.data.offered.size() > 0
        && request.resource.data.requested.size() > 0
        && request.resource.data.offered.size() <= 8
        && request.resource.data.requested.size() <= 8
        && request.resource.data.status == 'pending';
    }

    function acceptedTrade(tradeId) {
      return getAfter(/databases/$(database)/documents/trades/$(tradeId)).data;
    }

    function singleStickerTrade(trade) {
      return trade.offered is list
        && trade.requested is list
        && trade.offered.size() == 1
        && trade.requested.size() == 1;
    }

    function tradeAllowsInventoryCreate(userId, stickerId, trade) {
      return singleStickerTrade(trade)
        && request.auth.uid == trade.toUserId
        && trade.status == 'accepted'
        && (
          (userId == trade.fromUserId && stickerId == trade.requested[0]) ||
          (userId == trade.toUserId && stickerId == trade.offered[0])
        );
    }

    function tradeAllowsInventoryUpdate(userId, stickerId, trade) {
      return singleStickerTrade(trade)
        && request.auth.uid == trade.toUserId
        && trade.status == 'accepted'
        && (
          (
            userId == trade.fromUserId &&
            stickerId == trade.offered[0] &&
            request.resource.data.copies == resource.data.copies - 1
          ) ||
          (
            userId == trade.fromUserId &&
            stickerId == trade.requested[0] &&
            request.resource.data.copies == resource.data.copies + 1
          ) ||
          (
            userId == trade.toUserId &&
            stickerId == trade.offered[0] &&
            request.resource.data.copies == resource.data.copies + 1
          ) ||
          (
            userId == trade.toUserId &&
            stickerId == trade.requested[0] &&
            request.resource.data.copies == resource.data.copies - 1
          )
        );
    }

    function safeTradeInventoryCreate(userId, stickerId) {
      let trade = acceptedTrade(request.resource.data.lastTradeId);
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'stickerId',
          'copies',
          'lastTradeId',
          'updatedAt'
        ])
        && request.resource.data.stickerId == stickerId
        && request.resource.data.copies == 1
        && request.resource.data.lastTradeId is string
        && tradeAllowsInventoryCreate(userId, stickerId, trade);
    }

    function safeTradeInventoryUpdate(userId, stickerId) {
      let trade = acceptedTrade(request.resource.data.lastTradeId);
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'stickerId',
          'copies',
          'lastOpeningId',
          'lastTradeId',
          'updatedAt'
        ])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'copies',
          'lastTradeId',
          'updatedAt'
        ])
        && request.resource.data.stickerId == resource.data.stickerId
        && request.resource.data.stickerId == stickerId
        && request.resource.data.lastTradeId is string
        && tradeAllowsInventoryUpdate(userId, stickerId, trade);
    }

    function safeTradeAccept() {
      return signedIn()
        && request.auth.uid == resource.data.toUserId
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'acceptedAt',
          'updatedAt'
        ])
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.toUserId == resource.data.toUserId
        && request.resource.data.roomId == resource.data.roomId
        && request.resource.data.offered == resource.data.offered
        && request.resource.data.requested == resource.data.requested
        && request.resource.data.status == 'accepted'
        && singleStickerTrade(resource.data);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && safeProfileCreate();
      allow update: if isOwner(userId)
        && (
          safeProfileUpdate() ||
          safeStarterClaim() ||
          safeClientPackOpenProfile() ||
          safeMissionRewardProfile(userId)
        );
      allow delete: if false;
    }

    match /users/{userId}/inventory/{stickerId} {
      allow read: if isOwner(userId);
      allow create: if safeInventoryCreate(userId, stickerId) || safeTradeInventoryCreate(userId, stickerId);
      allow update: if safeInventoryUpdate(userId, stickerId) || safeTradeInventoryUpdate(userId, stickerId);
      allow delete: if false;
    }

    match /users/{userId}/missions/{missionId} {
      allow read: if isOwner(userId);
      allow create: if safeMissionClaim(userId, missionId);
      allow update, delete: if false;
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if safeRoomCreate();
      allow update: if safeRoomUpdate();
      allow delete: if false;

      match /members/{userId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
        allow create, update: if isOwner(userId)
          && request.auth.uid in getAfter(/databases/$(database)/documents/rooms/$(roomId)).data.memberIds;
        allow delete: if false;
      }
    }

    match /trades/{tradeId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      allow create: if safeTradeCreate();
      allow update: if safeTradeAccept();
      allow delete: if false;
    }

    match /packOpenings/{openingId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'userId',
          'packType',
          'stickerIds',
          'source',
          'createdAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.packType is string
        && request.resource.data.stickerIds is list
        && request.resource.data.stickerIds.size() == 5
        && request.resource.data.source == 'firestore-client'
        && clientPackOpenAfter(request.auth.uid);
      allow update, delete: if false;
    }

    match /catalog/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
