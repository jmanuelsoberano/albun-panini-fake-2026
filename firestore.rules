rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function safeProfileCreate() {
      return request.resource.data.keys().hasOnly([
          'nickname',
          'avatarId',
          'coins',
          'packsAvailable',
          'packsOpened',
          'starterPackClaimed',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.nickname is string
        && request.resource.data.avatarId is string
        && request.resource.data.coins == 0
        && request.resource.data.packsAvailable == 0
        && request.resource.data.packsOpened == 0
        && request.resource.data.starterPackClaimed == false;
    }

    function safeProfileUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'nickname',
        'avatarId',
        'updatedAt'
      ]);
    }

    function safeStarterClaim() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'starterPackClaimed',
          'packsAvailable',
          'updatedAt'
        ])
        && resource.data.starterPackClaimed == false
        && request.resource.data.starterPackClaimed == true
        && request.resource.data.packsAvailable == resource.data.packsAvailable + 1;
    }

    function safeClientPackOpenProfile() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'packsAvailable',
          'packsOpened',
          'updatedAt'
        ])
        && resource.data.packsAvailable > 0
        && request.resource.data.packsAvailable == resource.data.packsAvailable - 1
        && request.resource.data.packsOpened == resource.data.packsOpened + 1;
    }

    function clientPackOpenAfter(userId) {
      let before = get(/databases/$(database)/documents/users/$(userId)).data;
      let after = getAfter(/databases/$(database)/documents/users/$(userId)).data;
      return after.packsAvailable == before.packsAvailable - 1
        && after.packsOpened == before.packsOpened + 1;
    }

    function validClientOpening(userId, openingId, stickerId) {
      let opening = getAfter(/databases/$(database)/documents/packOpenings/$(openingId)).data;
      return opening.userId == userId
        && opening.source == 'firestore-client'
        && opening.stickerIds is list
        && opening.stickerIds.size() == 5
        && stickerId in opening.stickerIds;
    }

    function safeInventoryCreate(userId, stickerId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'stickerId',
          'copies',
          'lastOpeningId',
          'updatedAt'
        ])
        && request.resource.data.stickerId == stickerId
        && request.resource.data.copies == 1
        && request.resource.data.lastOpeningId is string
        && clientPackOpenAfter(userId)
        && validClientOpening(userId, request.resource.data.lastOpeningId, stickerId);
    }

    function safeInventoryUpdate(userId, stickerId) {
      return isOwner(userId)
        && request.resource.data.keys().hasOnly([
          'stickerId',
          'copies',
          'lastOpeningId',
          'updatedAt'
        ])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'copies',
          'lastOpeningId',
          'updatedAt'
        ])
        && request.resource.data.stickerId == resource.data.stickerId
        && request.resource.data.stickerId == stickerId
        && request.resource.data.copies == resource.data.copies + 1
        && request.resource.data.lastOpeningId is string
        && clientPackOpenAfter(userId)
        && validClientOpening(userId, request.resource.data.lastOpeningId, stickerId);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId) && safeProfileCreate();
      allow update: if isOwner(userId)
        && (safeProfileUpdate() || safeStarterClaim() || safeClientPackOpenProfile());
      allow delete: if false;
    }

    match /users/{userId}/inventory/{stickerId} {
      allow read: if isOwner(userId);
      allow create: if safeInventoryCreate(userId, stickerId);
      allow update: if safeInventoryUpdate(userId, stickerId);
      allow delete: if false;
    }

    match /users/{userId}/missions/{missionId} {
      allow read: if isOwner(userId);
      allow write: if false; // Solo Cloud Functions debe otorgar recompensas.
    }

    match /rooms/{roomId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow delete: if false;

      match /members/{userId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);
      }
    }

    match /trades/{tradeId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.fromUserId
        && request.resource.data.status == 'pending';
      allow update, delete: if false; // Aceptar/cancelar debe pasar por Cloud Functions.
    }

    match /packOpenings/{openingId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'userId',
          'packType',
          'stickerIds',
          'source',
          'createdAt'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.packType is string
        && request.resource.data.stickerIds is list
        && request.resource.data.stickerIds.size() == 5
        && request.resource.data.source == 'firestore-client'
        && clientPackOpenAfter(request.auth.uid);
      allow update, delete: if false;
    }

    match /catalog/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
