{
  "name": "web",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\" \"scripts/**/*.mjs\" \"*.{json,md}\"",
    "format:write": "prettier --write \"src/**/*.{ts,html,css}\" \"scripts/**/*.mjs\" \"*.{json,md}\"",
    "check:angular-practices": "node scripts/check-angular-practices.mjs",
    "smoke:focusables": "node scripts/smoke-focusables.mjs",
    "smoke:hosting": "node scripts/smoke-hosting.mjs",
    "smoke:keyboard-real": "playwright test scripts/smoke-keyboard-real.spec.mjs --browser=chromium --reporter=line --workers=1",
    "verify:migration": "node scripts/verify-migration.mjs"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "^22.22.3 || ^24.15.0 || >=26.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "firebase": "^12.15.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.2",
    "@angular/cli": "^22.0.2",
    "@angular/compiler-cli": "^22.0.0",
    "@playwright/test": "^1.61.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
